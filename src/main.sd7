$ include "seed7_05.s7i";
  include "nstdlibs.s7i";

const proc: main is func
	local
		var integer:     coeffCount is integer.value;
		var pointArray2: pointData  is pointArray2.value;
	begin
		parseArgv(argv(PROGRAM));
		getDataFromFile(
		                argv(PROGRAM)[1],
		                coeffCount,
		                pointData
		                );
		sortPoint(pointData);
		parseData(pointData);
		removeDuplicate(pointData);
	end func;
